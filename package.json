{
  "name": "applypilot",
  "version": "0.1.0",
  "private": true,
  "description": "A full-stack job application tracker and CV/job-description match assistant for software students and junior developers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
